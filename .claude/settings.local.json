      "Bash(eval:*)",

      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(zsh:*)",
      "Bash(dash:*)",

      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(perl:*)",
