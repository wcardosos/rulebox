      "Bash(telnet:*)",
      "Bash(nmap:*)",
      "Bash(socat:*)",

      "Bash(docker:*)",
      "Bash(podman:*)",

      "Bash(base64:*)",
      "Bash(xxd:*)",
      "Bash(dd:*)",
      "Bash(mkfifo:*)",

      "Bash(git clone:*)",
